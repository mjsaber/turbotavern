# Copy to keystore.properties (gitignored) and fill in to sign RELEASE builds.
# Generate an upload key:
#   keytool -genkey -v -keystore turbotavern-upload.jks -alias upload \
#           -keyalg RSA -keysize 2048 -validity 10000
storeFile=/absolute/path/to/turbotavern-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
